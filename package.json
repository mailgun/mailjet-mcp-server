{
  "name": "mailjet-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node --watch src/mailjet-mcp.js",
    "start:clean": "echo Removing cache and clearing local oauth callback port && lsof -ti :43529 | xargs kill -9 && rm -rf ~/.mcp-auth && yarn start",
    "start:ngrok": "ngrok http 3000 --config ngrok.yml",
    "test": "NODE_ENV=test node --test tests/mailjet-mcp.test.js"
  },
  "keywords": [
    "AI",
    "artificial intelligence",
    "MCP",
    "model context protocol"
  ],
  "author": "Orville Bennett",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "zod": "^3.25.30"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.50"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
